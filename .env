# === 인프라 ===
POSTGRES_VERSION=17
DB_URL=jdbc:postgresql://localhost:5433/docgraph
DB_USERNAME=docgraph
AI_OPENAI_BASE_URL=https://api.openai.com
NOTION_AUTHORIZATION_URI=https://api.notion.com/v1/oauth/authorize
NOTION_TOKEN_URI=https://api.notion.com/v1/oauth/token

# === 시크릿 — .env.local에서 override ===
DB_PASSWORD=

# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# AI 어댑터 — 모델은 정확도/비용 평가 후 결정 (예: gpt-4o-mini)
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL=